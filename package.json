{
  "name": "@docmesa/docs",
  "private": true,
  "type": "module",
  "scripts": {
    "install:hooks": "lefthook install",
    "commit": "commit",
    "commitlint": "commitlint",
    "format:check:prettier": "prettier --check .",
    "format:fix:prettier": "prettier --write .",
    "format:check": "run-s format:check:*",
    "format:fix": "run-s format:fix:*",
    "lint:check": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "fix": "run-s *:fix",
    "sync": "astro sync",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "clean": "rimraf .turbo .astro dist node_modules",
    "pre-commit-tasks": "turbo format:check lint:check format:check build",
    "ci:smoke-test": "turbo format:check lint:check build"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.34.1",
    "astro": "^5.6.1",
    "sharp": "^0.34.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@commitlint/prompt-cli": "19.8.1",
    "@commitlint/types": "19.8.1",
    "@eslint/js": "9.26.0",
    "@typescript-eslint/eslint-plugin": "8.32.1",
    "@typescript-eslint/parser": "8.32.1",
    "eslint": "9.26.0",
    "eslint-plugin-astro": "1.3.1",
    "eslint-plugin-turbo": "2.5.3",
    "lefthook": "1.11.12",
    "npm-run-all2": "7.0.2",
    "prettier": "3.5.3",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-organize-imports": "4.1.0",
    "rimraf": "6.0.1",
    "turbo": "2.5.3",
    "typescript-eslint": "8.32.1"
  },
  "packageManager": "pnpm@10.11.0"
}
